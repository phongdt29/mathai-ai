# Frontend environment example

NODE_ENV=development

# Browser API base URL.
# Development/test may omit this and default browser API calls to /api.
# Production build requires an explicit absolute http(s) URL that does not point to localhost.
# Production example: https://api.your-domain.example/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Next.js development rewrite target for /api/* server rewrites; optional.
# Defaults to http://localhost:3001/api when unset. Production rewrites are disabled.
BACKEND_API_URL=http://localhost:3001/api

# Demo login UI is visible automatically in NODE_ENV=development.
# Set to true only for an explicitly approved demo deployment; keep false/empty in production.
# The dev/staging MongoDB seed creates demo users with password MathAI@Demo123 by default.
# If backend seed uses SEED_DEMO_PASSWORD, keep any demo UI/docs aligned manually; do not expose production secrets here.
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false

# Sentry (Phase 3) — error tracking for frontend.
# Leave empty to disable Sentry in development.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
