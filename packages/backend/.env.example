# Backend environment example
# Active runtime: MongoDB via Mongoose. `database/schema.sql` is a SQL reference/blueprint,
# not the active backend runtime schema. Do not configure MySQL/SQL keys for runtime.

NODE_ENV=development
BACKEND_PORT=3001
# Một hoặc nhiều origin phân tách bằng dấu phẩy, ví dụ:
# CORS_ORIGIN=https://app.mathai.vn,https://partner.example.com
CORS_ORIGIN=http://localhost:3444
APP_BASE_URL=http://localhost:3444

# Số hop reverse proxy tin cậy (nginx/load balancer) để rate limit theo IP thật.
# Đặt 1 khi chạy sau một lớp proxy; để trống khi chạy trực tiếp.
TRUST_PROXY=

# Cổng API tích hợp ngoài (server-to-server) — /api/v1/external/*.
# Một hoặc nhiều API key phân tách bằng dấu phẩy; để trống để tắt cổng này.
# Sinh key: openssl rand -hex 32
EXTERNAL_API_KEYS=

# MongoDB runtime
# Development/test may use the local default. Production must set an explicit non-localhost MongoDB URI.
MONGODB_URI=mongodb://localhost:27017
DB_NAME=mathai

# JWT
# Development/test may use local defaults when unset, but every shared/staging/production environment
# must set long, random, distinct values. Never commit real secrets.
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-development-secret
JWT_EXPIRES_IN=7d

# Password reset email. Local/default console provider logs the reset message instead of sending mail.
# Staging/production should use EMAIL_PROVIDER=http with a HTTPS email API and secret key.
EMAIL_PROVIDER=console
EMAIL_API_URL=
EMAIL_API_KEY=
EMAIL_FROM="MathAI <no-reply@localhost>"
EMAIL_REPLY_TO="support@mathai.vn"

# Demo Bearer tokens (demo-token-admin/teacher/student/parent) are disabled by default.
# Set to true only in non-production local/demo environments; production always rejects them.
ENABLE_DEMO_AUTH_TOKENS=false

# MongoDB seed is intended for local/dev/staging only; it never enables demo token bypass.
# Demo login accounts created by `npm run seed` use real bcrypt password hashes.
# Leave empty to use the documented dev/staging password MathAI@Demo123, or override per environment.
SEED_DEMO_PASSWORD=

# OpenAI / AI tutor integration. OPENAI_API_KEY is required only when AI-backed runtime paths are enabled.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Object Storage (OCR images, submission attachments, avatars)
# STORAGE_PROVIDER: local (dev) | s3 (production — S3-compatible: AWS S3, Cloudflare R2, MinIO)
STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_DIR=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=ap-southeast-1
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_OCR_RETENTION_DAYS=90
OCR_DAILY_QUOTA_PER_STUDENT=30

# Scheduler / Cron jobs
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
ATTENDANCE_LATE_TO_PENDING_GRACE_MINUTES=15
ATTENDANCE_FINAL_GRACE_MINUTES=30

# SMS Notification (Phase 2)
# SMS_PROVIDER: console (dev) | twilio | esms (production)
SMS_PROVIDER=console
SMS_API_URL=
SMS_API_KEY=
SMS_FROM_NUMBER=

# Push Notification (Phase 2)
# PUSH_PROVIDER: console (dev) | fcm | web-push (production)
PUSH_PROVIDER=console
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_CONTACT=mailto:support@mathai.vn

# Phase 1+ feature flags. Accepted values: true/false, 1/0, yes/no, on/off, enabled/disabled.
FEATURE_SCHEDULER_ENABLED=true
FEATURE_ATTENDANCE_AUTO_FINALIZE=true
FEATURE_RISK_DAILY_BATCH=true

# Payment — VNPAY (Phase 3)
# VNPAY sandbox/production credentials. Leave empty when payment features are not configured.
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
PAYMENT_VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
PAYMENT_VNPAY_RETURN_URL=http://localhost:3444/dashboard/billing/return?vnpay=1

# Payment — MOMO (Phase 3)
# MOMO sandbox/production credentials. Leave empty when payment features are not configured.
PAYMENT_MOMO_PARTNER_CODE=
PAYMENT_MOMO_ACCESS_KEY=
PAYMENT_MOMO_SECRET_KEY=
PAYMENT_MOMO_PAYMENT_URL=https://test-payment.momo.vn/v2/gateway/api/create
PAYMENT_MOMO_RETURN_URL=http://localhost:3444/dashboard/billing/return?momo=1
PAYMENT_MOMO_IPN_URL=http://localhost:3001/api/webhooks/momo

# Payment — SePay bank transfer / QR
# Sandbox values may also be configured by admin UI; production secrets should be supplied from env only.
PAYMENT_SEPAY_API_KEY=
PAYMENT_SEPAY_WEBHOOK_SECRET=
PAYMENT_SEPAY_BANK_ACCOUNT=
PAYMENT_SEPAY_BANK_CODE=
PAYMENT_SEPAY_ACCOUNT_NAME=
PAYMENT_SEPAY_BANK_NAME=
PAYMENT_SEPAY_QR_TEMPLATE_URL=

# Payment general
PAYMENT_INTENT_TTL_SECONDS=900

# Monitoring & Observability (Phase 3)
# Sentry DSN for error tracking. Leave empty to disable Sentry in development.
SENTRY_DSN=
# Prometheus metrics bearer token for /metrics endpoint. Leave empty to disable auth in dev.
METRICS_TOKEN=
# Log level: debug | info | warn | error. Defaults to info.
LOG_LEVEL=info

# Phase 3 feature flags
FEATURE_BILLING_ENFORCEMENT=false
FREE_DAILY_QUOTA=5

# Phase 6 feature flags. Accepted values: true/false, 1/0, yes/no, on/off, enabled/disabled.
# Security and observability features default to true in code; deployment checkpoint automation is opt-in.
FEATURE_SCOPED_AUTHORIZATION_ENFORCEMENT=true
FEATURE_AUDIT_LOGGING=true
FEATURE_AI_SAFETY_GUARD=true
FEATURE_ANTI_FRAUD_SIGNAL_GENERATION=true
FEATURE_GRADEBOOK_SUMMARIES=true
FEATURE_DEPLOYMENT_CHECKPOINTS=false
