{
	"name": "@mathai/backend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"dev:worker": "tsx watch src/worker.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"start:worker": "node dist/worker.js",
		"seed": "tsx scripts/seed.ts",
		"seed:dev": "tsx scripts/seed.ts",
		"seed:staging": "tsx scripts/seed.ts",
		"test": "node --import tsx --test \"src/**/*.test.ts\" \"scripts/**/*.test.ts\"",
		"test:ci": "node --import tsx --test --test-reporter=tap \"src/**/*.test.ts\" \"scripts/**/*.test.ts\"",
		"backfill:assessment-points": "tsx scripts/backfill-assessment-attempt-points.ts",
		"backfill:assessment-classifications": "tsx scripts/backfill-assessment-classifications.ts",
		"send:parent-weekly-reports": "tsx scripts/send-parent-weekly-reports.ts",
		"migrate:point-ledger-indexes": "tsx scripts/migrate-point-ledger-indexes.ts"
	},
	"dependencies": {
		"@sentry/node": "^10.53.1",
		"@sinonjs/fake-timers": "^15.4.0",
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.18.2",
		"express-rate-limit": "^8.3.2",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.23.0",
		"morgan": "^1.10.1",
		"multer": "^2.1.1",
		"node-cron": "^4.2.1",
		"openai": "^4.52.0",
		"prom-client": "^15.1.3",
		"ulid": "^3.0.2",
		"web-push": "^3.6.7",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^20.12.12",
		"@types/node-cron": "^3.0.11",
		"@types/web-push": "^3.6.4",
		"fast-check": "^4.8.0",
		"tsx": "^4.11.0",
		"typescript": "^5.4.5"
	}
}
